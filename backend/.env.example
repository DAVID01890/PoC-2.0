# Database: SQLite (local) o Turso (cloud)
SQLITE_PATH=local.db
# TURSO_DATABASE_URL=libsql://...
# TURSO_AUTH_TOKEN=...

# API Config
API_TITLE=Scrum Management API
API_VERSION=1.0.0
CORS_ORIGINS=*
DEBUG=1
PORT=8000

# Auth
JWT_SECRET=CHANGE-ME-IN-PRODUCTION--32bytes!
JWT_ALGORITHM=HS256
AUTH_PROVIDER=internal

# Outbox (opcional)
# OUTBOX_WEBHOOK_URL=https://...    