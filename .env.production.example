# =========================================================================
# .env.production.example — Configuración de Producción
# Renombra este archivo a .env en tu servidor o configúralo en Railway
# =========================================================================

# Database: Turso (Requerido para producción)
TURSO_DATABASE_URL=libsql://tu-instancia.aws-us-west-2.turso.io
TURSO_AUTH_TOKEN=TU_TOKEN_DE_TURSO_AQUI

# API Config
API_TITLE=Scrum Management API
API_VERSION=1.0.0
CORS_ORIGINS=https://tu-dominio-frontend.com
DEBUG=0
PORT=8000

# Auth JWT — OBLIGATORIO — Genera una clave hexadecimal segura
JWT_SECRET=tu-clave-secreta-hexadecimal-de-64-caracteres

# Gemini AI — Opcional
GEMINI_API_KEY=tu-api-key-de-google-gemini

# Administrador Inicial por Defecto (Se crea automáticamente si la BD está limpia)
DEFAULT_ADMIN_EMAIL=admin@tudominio.com
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_PASSWORD=contrasena-muy-segura-aqui

# URL de la API del Backend (Usada durante la compilación del contenedor frontend)
REACT_APP_API_URL=https://tu-dominio-backend.com/api/v1
