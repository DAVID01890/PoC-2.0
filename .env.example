# =============================================
# .env.example — Copia y renombra a .env
# NO subas el .env real a control de versiones
# =============================================

# Database: Turso (cloud) — Opcional
# Si está configurado, tiene prioridad sobre SQLite
TURSO_DATABASE_URL=libsql://tu-instancia.aws-us-west-2.turso.io
TURSO_AUTH_TOKEN=TU_TOKEN_AQUI

# Database: SQLite (local, fallback)
SQLITE_PATH=local.db

# API Config
API_TITLE=Scrum Management API
API_VERSION=1.0.0
CORS_ORIGINS=http://localhost:3000
DEBUG=0
PORT=8000

# Auth JWT — OBLIGATORIO — Generar con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=8a05f80e4f9b10d735e467778e5551dc8a1ddd77eb9d25eb4ef0859ab2ef97ad
JWT_ALGORITHM=HS256

# Gemini AI — Opcional
GEMINI_API_KEY=TU_API_KEY_DE_GOOGLE_AQUI

# Outbox Webhook — Opcional
OUTBOX_WEBHOOK_URL=
